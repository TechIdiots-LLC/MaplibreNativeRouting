<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:routing="clr-namespace:MaplibreNative.Routing.Controls"
             x:DataType="routing:NavigationPanelViewModel"
             x:Class="MaplibreNative.Routing.Controls.NavigationPanel">

    <Grid RowDefinitions="Auto,Auto" BackgroundColor="#1A1A2E">

        <!-- Highway warning bar -->
        <Border Grid.Row="0"
                BackgroundColor="#FF6600"
                Padding="12,8"
                IsVisible="{Binding HasHighwayWarning}">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding HighwayWarningText}"
                       TextColor="White" FontSize="12"
                       VerticalOptions="Center" />
                <Button Grid.Column="1" Text="✕"
                        Command="{Binding DismissHighwayWarningCommand}"
                        BackgroundColor="Transparent" TextColor="White"
                        Padding="8,0" FontSize="13" />
            </Grid>
        </Border>

        <!-- Main instruction panel -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto"
              Padding="12,10" ColumnSpacing="12"
              IsVisible="{Binding IsNavigating}">

            <!-- Maneuver icon (text-based for now; swap for image in M5 polish) -->
            <Border WidthRequest="48" HeightRequest="48"
                    BackgroundColor="#2563EB"
                    StrokeShape="RoundRectangle 8"
                    VerticalOptions="Center">
                <Label Text="{Binding ManeuverIcon}"
                       TextColor="White" FontSize="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Instruction + street name -->
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Instruction}"
                       TextColor="White" FontSize="15"
                       FontAttributes="Bold"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding DistanceLabel}"
                       TextColor="#9CA3AF" FontSize="12" />
            </VerticalStackLayout>

            <!-- ETA / remaining distance -->
            <VerticalStackLayout Grid.Column="2" Spacing="2"
                                 VerticalOptions="Center"
                                 HorizontalOptions="End">
                <Label Text="{Binding EtaLabel}"
                       TextColor="White" FontSize="14" FontAttributes="Bold"
                       HorizontalOptions="End" />
                <Label Text="{Binding TotalDistanceLabel}"
                       TextColor="#9CA3AF" FontSize="11"
                       HorizontalOptions="End" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentView>
