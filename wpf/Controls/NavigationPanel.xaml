<UserControl x:Class="MaplibreNative.Routing.Wpf.Controls.NavigationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Highway warning bar -->
        <Border Grid.Row="0" Background="#FF6600" Padding="12,8"
                Visibility="{Binding HasHighwayWarning, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding HighwayWarningText}"
                           Foreground="White" FontSize="12"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="✕"
                        Command="{Binding DismissHighwayWarningCommand}"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" Padding="8,0" FontSize="13"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Main instruction panel -->
        <Grid Grid.Row="1" Margin="12,10"
              Visibility="{Binding IsNavigating, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Maneuver icon -->
            <Border Width="48" Height="48" Background="#2563EB" CornerRadius="8"
                    VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="{Binding ManeuverIcon}"
                           Foreground="White" FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Instruction + step distance -->
            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="{Binding Instruction}"
                           Foreground="White" FontSize="15" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding DistanceLabel}"
                           Foreground="#9CA3AF" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>

            <!-- ETA / remaining distance -->
            <StackPanel Grid.Column="2" Orientation="Vertical"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{Binding EtaLabel}"
                           Foreground="White" FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding TotalDistanceLabel}"
                           Foreground="#9CA3AF" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,2,0,0" />
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
